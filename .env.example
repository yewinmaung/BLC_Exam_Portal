APP_NAME="Believe Exam"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Default admin created automatically on startup if missing
DEFAULT_ADMIN_EMAIL=admin@blc.edu.mm
DEFAULT_ADMIN_PASSWORD=password
DEFAULT_ADMIN_NAME="BLC Administrator"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=b_exam
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ──────────────────────────────────────────────────────────────
# MAIL — Brevo (Sendinblue) SMTP
# Get credentials: https://app.brevo.com/settings/keys/smtp
# ──────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=                        # your Brevo login email
MAIL_PASSWORD=                        # your Brevo SMTP key (not account password)
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo SMTP key (same as MAIL_PASSWORD above — kept for reference)
BREVO_SMTP_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
